<Window x:Class="CrtOverlayApp.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CRT Overlay Settings"
        Width="520"
        Height="860"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#111315"
        Foreground="#F1F3F5">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#111315" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#171A1D" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#2A2F36" />
        <SolidColorBrush x:Key="MutedForegroundBrush" Color="#A9B1BA" />
        <SolidColorBrush x:Key="AccentBrush" Color="#62D2A2" />
        <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#1D2228" />
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#252B33" />
        <SolidColorBrush x:Key="ButtonPressedBrush" Color="#2D3540" />
        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#F1F3F5" /></Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F1F3F5" />
            <Setter Property="Background" Value="{StaticResource ButtonBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="CheckBox"><Setter Property="Foreground" Value="#F1F3F5" /><Setter Property="Margin" Value="0,16,0,0" /></Style>
        <Style TargetType="Slider"><Setter Property="Margin" Value="0,6,0,0" /></Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#F1F3F5" />
            <Setter Property="Background" Value="#1D2228" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>
    </Window.Resources>
    <Grid Background="{StaticResource WindowBackgroundBrush}">
        <Border Margin="14" Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="18">
                    <TextBlock Text="CRT Overlay Settings" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <TextBlock Text="Changes preview live while this window is open. Apply saves them." Foreground="{StaticResource MutedForegroundBrush}" Margin="0,0,0,16" />
                    <TextBlock Text="Presets" FontWeight="SemiBold" />
                    <WrapPanel Margin="0,6,0,0">
                        <Button Width="110" Margin="0,0,8,8" Content="Green Terminal" Click="PresetGreenTerminal_Click" />
                        <Button Width="100" Margin="0,0,8,8" Content="Blue Monitor" Click="PresetBlueMonitor_Click" />
                        <Button Width="110" Margin="0,0,8,8" Content="Amber Terminal" Click="PresetAmberTerminal_Click" />
                        <Button Width="90" Margin="0,0,8,8" Content="Sony PVM" Click="PresetSonyPvm_Click" />
                        <Button Width="80" Margin="0,0,8,8" Content="VHS" Click="PresetVhs_Click" />
                    </WrapPanel>
                    <TextBlock Text="Master opacity" FontWeight="SemiBold" Margin="0,10,0,0" />
                    <Slider Minimum="0.05" Maximum="1" SmallChange="0.01" Value="{Binding WorkingCopy.MasterOpacity}" />
                    <TextBlock Text="Glow strength" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <Slider Minimum="0" Maximum="1" SmallChange="0.01" Value="{Binding WorkingCopy.GlowStrength}" />
                    <TextBlock Text="Horizontal bloom / phosphor bleed" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <Slider Minimum="0" Maximum="1" SmallChange="0.01" Value="{Binding WorkingCopy.HorizontalBloom}" />
                    <TextBlock Text="Vignette strength" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <Slider Minimum="0" Maximum="1" SmallChange="0.01" Value="{Binding WorkingCopy.VignetteStrength}" />
                    <TextBlock Text="Reflection strength" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <Slider Minimum="0" Maximum="0.5" SmallChange="0.01" Value="{Binding WorkingCopy.ReflectionStrength}" />
                    <TextBlock Text="Scanline spacing" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <Slider Minimum="2" Maximum="8" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding WorkingCopy.ScanlineSpacing}" />
                    <TextBlock Text="Scanline opacity" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <Slider Minimum="0" Maximum="0.4" SmallChange="0.01" Value="{Binding WorkingCopy.ScanlineOpacity}" />
                    <TextBlock Text="Scanline softness" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <Slider Minimum="0" Maximum="1" SmallChange="0.01" Value="{Binding WorkingCopy.ScanlineSoftness}" />
                    <TextBlock Text="Phosphor mask strength" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <Slider Minimum="0" Maximum="1" SmallChange="0.01" Value="{Binding WorkingCopy.PhosphorStrength}" />
                    <TextBlock Text="Phosphor mask scale" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <Slider Minimum="1" Maximum="4" SmallChange="0.25" Value="{Binding WorkingCopy.PhosphorScale}" />
                    <TextBlock Text="Phosphor mask type" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <ComboBox SelectedValue="{Binding WorkingCopy.MaskType}" SelectedValuePath="Tag">
                        <ComboBoxItem Content="RGB stripe" Tag="0" />
                        <ComboBoxItem Content="Slot mask" Tag="1" />
                        <ComboBoxItem Content="Aperture grille" Tag="2" />
                    </ComboBox>
                    <TextBlock Text="Noise density" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <Slider Minimum="0" Maximum="1" SmallChange="0.01" Value="{Binding WorkingCopy.NoiseDensity}" />
                    <TextBlock Text="Noise opacity" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <Slider Minimum="0" Maximum="0.25" SmallChange="0.01" Value="{Binding WorkingCopy.NoiseOpacity}" />
                    <TextBlock Text="Gamma" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <Slider Minimum="0.7" Maximum="1.4" SmallChange="0.01" Value="{Binding WorkingCopy.Gamma}" />
                    <TextBlock Text="Contrast" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <Slider Minimum="0.7" Maximum="1.4" SmallChange="0.01" Value="{Binding WorkingCopy.Contrast}" />
                    <TextBlock Text="Brightness" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <Slider Minimum="-0.25" Maximum="0.25" SmallChange="0.01" Value="{Binding WorkingCopy.Brightness}" />
                    <TextBlock Text="Tint opacity" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <Slider Minimum="0" Maximum="0.45" SmallChange="0.01" Value="{Binding WorkingCopy.TintOpacity}" />
                    <TextBlock Text="Tint color" FontWeight="SemiBold" Margin="0,12,0,4" />
                    <WrapPanel Margin="0,0,0,8">
                        <Button Width="70" Margin="0,0,8,8" Content="Green" Click="PresetGreen_Click" />
                        <Button Width="70" Margin="0,0,8,8" Content="Blue" Click="PresetBlue_Click" />
                        <Button Width="70" Margin="0,0,8,8" Content="Red" Click="PresetRed_Click" />
                        <Button Width="80" Margin="0,0,8,8" Content="Amber" Click="PresetAmber_Click" />
                        <Button Width="75" Margin="0,0,8,8" Content="White" Click="PresetWhite_Click" />
                    </WrapPanel>
                    <TextBlock Text="Tint red" FontWeight="SemiBold" />
                    <Slider Minimum="0" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding WorkingCopy.TintRed}" />
                    <TextBlock Text="Tint green" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <Slider Minimum="0" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding WorkingCopy.TintGreen}" />
                    <TextBlock Text="Tint blue" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <Slider Minimum="0" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding WorkingCopy.TintBlue}" />
                    <Border Margin="0,10,0,0" Height="34" CornerRadius="6" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1">
                        <Border.Background><SolidColorBrush Color="{Binding TintPreviewColor}" /></Border.Background>
                    </Border>
                    <TextBlock Text="Flicker strength" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <Slider Minimum="0" Maximum="0.12" SmallChange="0.005" Value="{Binding WorkingCopy.FlickerStrength}" />
                    <TextBlock Text="Screen jitter" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <Slider Minimum="0" Maximum="1.0" SmallChange="0.01" Value="{Binding WorkingCopy.ScreenJitter}" />
                    <TextBlock Text="Target FPS" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <ComboBox SelectedValue="{Binding WorkingCopy.TargetFps}" SelectedValuePath="Tag">
                        <ComboBoxItem Content="15 FPS" Tag="15" />
                        <ComboBoxItem Content="24 FPS" Tag="24" />
                        <ComboBoxItem Content="30 FPS" Tag="30" />
                        <ComboBoxItem Content="60 FPS" Tag="60" />
                    </ComboBox>
                    <TextBlock Text="Hotkeys: Ctrl+Alt+C toggle, Ctrl+Alt+1 Sony PVM, Ctrl+Alt+2 VHS, Ctrl+Alt+Up/Down intensity" TextWrapping="Wrap" Foreground="{StaticResource MutedForegroundBrush}" Margin="0,12,0,0" />
                    <CheckBox Content="Try to exclude overlay from screen capture" IsChecked="{Binding WorkingCopy.ExcludeFromCapture}" />
                    <WrapPanel Margin="0,20,0,0" HorizontalAlignment="Right">
                        <Button Width="90" Margin="0,0,8,0" Content="Reset" Click="Reset_Click" />
                        <Button Width="90" Margin="0,0,8,0" Content="Cancel" Click="Cancel_Click" />
                        <Button Width="90" Content="Apply" Click="Apply_Click" IsDefault="True" />
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>