<Window x:Class="CrtOverlayApp.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CRT Overlay Settings"
        Width="900"
        Height="700"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">

            <TabItem Header="Presets">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock FontSize="18" FontWeight="Bold" Text="Quick presets" Margin="0,0,0,10"/>

                        <WrapPanel>
                            <Button Content="Green Terminal" Click="PresetGreenTerminal_Click" Margin="4"/>
                            <Button Content="Blue Monitor" Click="PresetBlueMonitor_Click" Margin="4"/>
                            <Button Content="Amber Terminal" Click="PresetAmberTerminal_Click" Margin="4"/>
                            <Button Content="Sony PVM" Click="PresetSonyPvm_Click" Margin="4"/>
                            <Button Content="VHS" Click="PresetVhs_Click" Margin="4"/>
                            <Button Content="Arcade" Click="PresetArcade_Click" Margin="4"/>
                            <Button Content="Broadcast" Click="PresetBroadcast_Click" Margin="4"/>
                            <Button Content="Subtle CRT" Click="PresetSubtle_Click" Margin="4"/>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Visual">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">

                        <TextBlock Text="Master opacity"/>
                        <Slider Minimum="0.05" Maximum="1" Value="{Binding WorkingCopy.MasterOpacity}"/>

                        <TextBlock Text="Glow strength"/>
                        <Slider Minimum="0" Maximum="1" Value="{Binding WorkingCopy.GlowStrength}"/>

                        <TextBlock Text="Bloom"/>
                        <Slider Minimum="0" Maximum="1" Value="{Binding WorkingCopy.HorizontalBloom}"/>

                        <TextBlock Text="Vignette"/>
                        <Slider Minimum="0" Maximum="1" Value="{Binding WorkingCopy.VignetteStrength}"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Scanlines">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">

                        <TextBlock Text="Scanline spacing"/>
                        <Slider Minimum="2" Maximum="8" Value="{Binding WorkingCopy.ScanlineSpacing}"/>

                        <TextBlock Text="Scanline opacity"/>
                        <Slider Minimum="0" Maximum="0.4" Value="{Binding WorkingCopy.ScanlineOpacity}"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Tint">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">

                        <Button Content="Green" Click="PresetGreen_Click" Margin="4"/>
                        <Button Content="Blue" Click="PresetBlue_Click" Margin="4"/>
                        <Button Content="Red" Click="PresetRed_Click" Margin="4"/>
                        <Button Content="Amber" Click="PresetAmber_Click" Margin="4"/>

                        <TextBlock Text="Tint opacity"/>
                        <Slider Minimum="0" Maximum="0.45" Value="{Binding WorkingCopy.TintOpacity}"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Reset" Click="Reset_Click" Width="80" Margin="5"/>
            <Button Content="Cancel" Click="Cancel_Click" Width="80" Margin="5"/>
            <Button Content="Apply" Click="Apply_Click" Width="80" Margin="5"/>
        </StackPanel>

    </Grid>
</Window>
