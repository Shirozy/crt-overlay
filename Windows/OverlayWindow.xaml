<Window x:Class="CrtOverlayApp.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CrtOverlayApp.Controls"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        Focusable="False"
        WindowStartupLocation="Manual">
    <Grid IsHitTestVisible="False" Background="Transparent">
        <controls:CrtOverlayControl x:Name="OverlayControl"
                                    IsHitTestVisible="False" />
    </Grid>
</Window>
